{
  "$schema": "https://design-tokens.org/schema.json",
  "color": {
    "text": {
      "nw-primary": { "$value": "#1C1917", "$description": "Headlines, names" },
      "nw-secondary": { "$value": "#44403C", "$description": "Body text" },
      "nw-tertiary": { "$value": "#56524E", "$description": "Supporting text" },
      "nw-quaternary": { "$value": "#7A726C", "$description": "Labels, captions" }
    },
    "surface": {
      "app": { "$value": "#F5F5F4", "$description": "Page background" },
      "card": { "$value": "#FFFFFF", "$description": "Card surface" },
      "subtle": { "$value": "#F8F8F8", "$description": "Secondary surface" }
    },
    "border": {
      "default": { "$value": "#E7E5E4", "$description": "Card borders" },
      "strong": { "$value": "#D6D3D1", "$description": "Dividers" }
    },
    "brand": {
      "periwinkle-500": { "$value": "hsl(230 89% 67%)", "$description": "Primary CTA" },
      "periwinkle-600": { "$value": "hsl(235 80% 59%)", "$description": "Hover CTA" }
    },
    "recipient": {
      "lavender":    { "solid": "hsl(240 37% 66%)", "bg": "hsl(240 37% 90%)" },
      "evergreen":   { "solid": "hsl(147 22% 39%)", "bg": "hsl(147 22% 88%)" },
      "herb":        { "solid": "hsl(66 21% 44%)",  "bg": "hsl(66 21% 88%)" },
      "sage":        { "solid": "hsl(173 20% 40%)", "bg": "hsl(173 20% 88%)" },
      "sandalwood":  { "solid": "hsl(8 53% 60%)",   "bg": "hsl(8 53% 92%)" },
      "berry":       { "solid": "hsl(324 35% 60%)", "bg": "hsl(324 35% 92%)" },
      "plum":        { "solid": "hsl(301 37% 61%)", "bg": "hsl(301 37% 92%)" },
      "peach":       { "solid": "hsl(13 90% 60%)",  "bg": "hsl(13 90% 92%)" },
      "honey":       { "solid": "hsl(33 83% 47%)",  "bg": "hsl(33 83% 92%)" },
      "aqua":        { "solid": "hsl(186 55% 48%)", "bg": "hsl(186 55% 90%)" },
      "wildflower":  { "solid": "hsl(353 26% 60%)", "bg": "hsl(353 26% 92%)" },
      "mist":        { "solid": "hsl(205 19% 46%)", "bg": "hsl(205 19% 90%)" },
      "periwinkle":  { "solid": "hsl(230 89% 67%)", "bg": "hsl(219 100% 94%)" }
    }
  },
  "shadow": {
    "nw-xs": { "$value": "0 1px 2px rgba(23,20,18,0.05)" },
    "nw-sm": { "$value": "0 1px 3px rgba(23,20,18,0.1), 0 1px 2px -1px rgba(23,20,18,0.1)" },
    "nw-md": { "$value": "0 4px 6px -1px rgba(23,20,18,0.1), 0 2px 4px -2px rgba(23,20,18,0.1)" },
    "nw-lg": { "$value": "0 10px 15px -3px rgba(23,20,18,0.1), 0 4px 6px -4px rgba(23,20,18,0.1)" }
  },
  "radius": {
    "nw-sm": { "$value": "8px" },
    "nw-md": { "$value": "12px" },
    "nw-lg": { "$value": "16px" },
    "nw-xl": { "$value": "24px" }
  },
  "spacing": {
    "grid": "8pt",
    "scale": [4, 8, 12, 16, 20, 24, 32, 40, 48, 64]
  }
}
